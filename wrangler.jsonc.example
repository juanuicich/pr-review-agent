{
  "name": "pr-review-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-19",
  "compatibility_flags": ["nodejs_compat"],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "memory": "4096",
      "vcpu": "2",
      "disk": "4000"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox"]
    }
  ],
  // TODO: Create KV namespace via `wrangler kv namespace create KV` and update ID
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "TODO_CREATE_KV_NAMESPACE"
    }
  ],
  // Sandbox SDK requires this exact binding name for backup/restore
  "r2_buckets": [
    {
      "binding": "BACKUP_BUCKET",
      "bucket_name": "TODO_CREATE_R2_BUCKET"
    }
  ],
  "rules": [
    { "type": "Text", "globs": ["**/*.md"], "fallthrough": true },
    { "type": "Text", "globs": ["**/*.sh"] }
  ],
  "triggers": {
    "crons": ["*/10 * * * *"]
  },
  // Required secrets — set via: wrangler secret put <NAME>
  // - AUTH_TOKEN (shared secret for Worker auth)
  // - GH_TOKEN (GitHub PAT)
  // - LINEAR_API_KEY
  // - LLM_API_KEY (API key for the selected model provider)
  // - OPENCODE_MODEL (provider/model format, e.g. anthropic/claude-sonnet-4-6)
  // - REVIEW_WORKER_URL (deployed worker URL, e.g. https://pr-review-agent.<account>.workers.dev)
  "vars": {}
}
